{
    "version": 2,
    "framework": null,
    "functions": {
        "api/index.php": { "runtime": "vercel-php@0.9.0" }
    },
    "routes": [
        {
            "src": "/(.*\\.(css|js|png|jpg|jpeg|gif|svg|ico|woff|woff2|ttf|mp4|webm|webp))",
            "dest": "/public/$1"
        },
        {
            "src": "/(.*)",
            "dest": "/api/index.php?path=$1"
        }
    ],
    "env": {
        "APP_KEY": "base64:rHRUr0pvuYeOm5Of20TjNqWVIoi50fgM3w/TEi6RQAY=",
        "APP_ENV": "production",
        "APP_DEBUG": "false",
        "APP_URL": "https://nurbannxt.com",
        "APP_CONFIG_CACHE": "/tmp/config.php",
        "APP_EVENTS_CACHE": "/tmp/events.php",
        "APP_PACKAGES_CACHE": "/tmp/packages.php",
        "APP_ROUTES_CACHE": "/tmp/routes.php",
        "APP_SERVICES_CACHE": "/tmp/services.php",
        "VIEW_COMPILED_PATH": "/tmp",
        "DB_CONNECTION": "pgsql",
        "DB_SSLMODE": "require",
        "CACHE_DRIVER": "file",
        "LOG_CHANNEL": "stderr",
        "SESSION_DRIVER": "cookie"
    }
}